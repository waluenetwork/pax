{
  "productName": "tauri-pax-basic-example",
  "version": "0.1.0",
  "identifier": "com.pax.tauri.basic-example",
  "build": {
    "beforeDevCommand": "",
    "beforeBuildCommand": "",
    "frontendDist": "../dist"
  },
  "app": {
    "security": {
      "csp": null,
      "dangerousDisableAssetCspModification": true,
      "capabilities": ["default"]
    },
    "windows": [
      {
        "label": "main",
        "fullscreen": false,
        "resizable": true,
        "title": "Tauri Pax Basic Example",
        "width": 800,
        "height": 600,
        "center": true
      }
    ],
    "withGlobalTauri": true
  },
  "bundle": {
    "active": true,
    "targets": "all"
  },
  "plugins": {
    "core": {
      "enabled": true
    }
  }
}
