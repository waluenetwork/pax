    },
    "windows": [
      {
        "fullscreen": false,
        "resizable": true,
        "title": "Tauri Pax Basic Example",
        "width": 800,
        "height": 600,
        "center": true
      }
    ],
    "security": {
      "csp": null
    }
  }
}
